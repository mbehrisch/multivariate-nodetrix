t_crit <- qt(0.025, df = df, lower.tail = FALSE)
t_crit
# clear memory
rm(list = ls())
chisq.test(c(A = 250, B = 180, C = 200))
# chi_sq = 12.381
p_val <- 1 - pchisq(12.381, df = 2)
p_val
?pchisq
