oneday_men <- c(4, 6, 5, 4, 4, 8)
oneday_women <-c(4, 5, 6, 6, 2)
oneweek_men <- c(6, 8, 8, 5, 6, 8)
oneweek_women <- c(3, 4, 2, 1, 5)
var_women <- var(oneday_women)
var_women
var_men <- var(oneday_men)
var_men
df_women <- length(oneday_women) - 1
df_men <- length(oneday_men) - 1
# F = grooste var / kleinste var
f_value <- var_women / var_men
f_value
p_value <- 1-pf(f_value, df_women, df_men)
p_value
data_2 <- matrix(c(20, 10, 7, 3, 5, 15), ncol = 2, byrow = TRUE)
chisq.test(data_2, correct = TRUE)
# na aflezen in chisq.test kan je chi_sq ook invoeren.
cramer_V <- sqrt(chi_sq / (sum(obs_tot) * 1))
chi_sq <- sum((obs_men - exp_men)**2 / exp_men) + sum ((obs_women - exp_women)**2 / exp_women)
obs_men <- c(10, 3, 15)
obs_women <- c(20, 7, 5)
obs_tot <- obs_men + obs_women
exp_men <- (sum(obs_men) * obs_tot / sum(obs_tot))
exp_men
exp_women <- (sum(obs_women) * obs_tot / sum(obs_tot))
exp_women
chi_sq <- sum((obs_men - exp_men)**2 / exp_men) + sum ((obs_women - exp_women)**2 / exp_women)
chi_sq
# na aflezen in chisq.test kan je chi_sq ook invoeren.
cramer_V <- sqrt(chi_sq / (sum(obs_tot) * 1))
cramer_V
?chisq.test
