      "thresholds":          "Optional array for numerical tasks. Each entry: { value: number (km), direction: 'gt'|'lt', label: string }. Renders a vertical tick on the colour gradient at that distance and an example line in the thickness legend at the correct stroke width. 'gt' = '>' prefix, 'lt' = '<' prefix.",
      "startNode":           "Optional IATA code. When set, that node is pre-highlighted green (.node--start) when the task loads so participants can find the reference airport instantly.",
      "options":             "Required for multiple-choice only.",
      "correctAnswers":      "Array of accepted answers. For select-nodes all selected airports must appear in this array.",
      "diagram":             "Path to the dataset JSON."
    }
  },

