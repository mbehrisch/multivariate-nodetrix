      "order1": "SV0+Estimation → SV1+Structure → SV2+Browsing  → SV3+Attribute",
      "order2": "SV1+Estimation → SV2+Structure → SV3+Browsing  → SV0+Attribute",
      "order3": "SV2+Estimation → SV3+Structure → SV0+Browsing  → SV1+Attribute",
      "order4": "SV3+Estimation → SV0+Structure → SV1+Browsing  → SV2+Attribute"
    },
    "taskFields": {
      "id":             "Unique string identifier (e.g. 'T_O1_E'). Prefix T_O{order}_{E|S|B|A}.",
      "taskType":       "One of 'estimation' | 'structure' | 'browsing' | 'attribute'. For logging only.",
      "condition":      "Active encoding: 'baseline' | 'categorical' | 'numerical' | 'directional'.",
      "encodings":      "Array of encoding names. Categorical: 'color','dashing'. Numerical: 'color','thickness'. Directional: 'gradient','taper','arrows'. Empty array [] for baseline.",
      "filter":         "Optional. { 'type': 'deduplicate' } reduces 1 227 edges to 205 unique pairs for a clean, unambiguous graph. Applied to ALL tasks for visual consistency across conditions.",
      "description":    "Question text shown to the participant.",
      "colorKeywords":  "Optional. Array of { word, color } objects to highlight key terms in the description.",
      "answerType":     "'select-node' | 'multiple-choice'",
      "options":        "Required for multiple-choice only.",
      "correctAnswers": "Array of accepted answers. Multiple values = several nodes/options count as correct (e.g. both endpoints of an edge, or any leaf node for browsing tasks).",
      "diagram":        "Path to the dataset JSON."
    }
