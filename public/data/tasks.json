{
  "_doc": {
    "structure": "conditions[modality][sv].tasks[taskType] — 3 modalities × 4 SV levels × 4 task types = 48 task definitions. A participant session runs 16 tasks (1 modality × 4 SVs in Latin Square order × 4 task types).",
    "taskFields": {
      "id": "Unique string identifier, e.g. 'T_Cat_SV0_TE1'. Pattern: T_{Mod}_{SV}_{TaskType}.",
      "taskType": "One of 'estimation' | 'structure' | 'browsing' | 'attribute'. For logging only.",
      "condition": "Modality string: 'categorical' | 'numerical' | 'directional'. Used for logging and condition-derived tooltip defaults.",
      "encodings": "Array of active encoding names for this task. Categorical: 'baseline','color','dashing'. Numerical: 'baseline','color','thickness'. Directional: 'arrows','gradient','taper'. 'baseline' = edge-hover tooltip.",
      "filter": "Optional. { 'type': 'deduplicate' } reduces 1227 edges to 205 unique pairs. Omit for full-graph tasks.",
      "description": "Question text shown to the participant.",
      "colorKeywords": "Array of { word, color } objects to highlight key terms in the description.",
      "answerType": "'select-node' | 'select-nodes' | 'multiple-choice'.",
      "requiredSelections": "Required when answerType is 'select-nodes'. How many airports must be double-clicked.",
      "thresholds": "Optional array for numerical tasks. Each: { value: number (km), direction: 'gt'|'lt', label: string }.",
      "startNode": "Optional IATA code. Pre-highlighted green (.node--start) when the task loads.",
      "tooltipFields": "Optional. Array of fields for edge-hover tooltips: 'route','airline','country','distance','aircraft','all'.",
      "options": "Required for multiple-choice only. Array of answer strings.",
      "correctAnswers": "Array of accepted answer strings. Empty [] for postHocCheck tasks.",
      "postHocCheck": "If true, task is graded manually post-hoc; correctAnswers is empty.",
      "diagram": "Path to the dataset JSON."
    },
    "latinSquare": "4×4 balanced Latin Square over SV levels. Assign each participant an order (1–4) via URL ?order=1."
  },
